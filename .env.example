# --- Core ---
DATABASE_URL=postgres://hellopicnic:CHANGE_ME@postgres:5432/hellopicnic
APP_SECRET=            # 32+ random bytes, base64 — encrypts secrets at rest (openssl rand -base64 32)
AUTH_SECRET=           # Auth.js session secret (openssl rand -base64 32)
TZ=Europe/Amsterdam

# --- Storage (docs/ARCHITECTURE.md §3a) ---
DATA_DIR=./data
STORAGE_DRIVER=fs      # fs | s3
#S3_ENDPOINT=
#S3_BUCKET=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=

# --- LLM providers (server-side only; enable the ones you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- Integrations ---
PICNIC_API_BASE=https://storefront-prod.nl.picnicinternational.com/api
PICNIC_API_VERSION=17
BRING_API_KEY=
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# --- Testing ---
#FAKE_AI=1
#PLAYWRIGHT_CHROMIUM_EXECUTABLE=/opt/pw-browsers/chromium-1194/chrome-linux/chrome
