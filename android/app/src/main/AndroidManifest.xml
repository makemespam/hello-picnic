<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep links (docs/workpackages/WP-14 §1): tapping a
                 https://<domain>/recepten/... link (shared, or from a calendar-event
                 description built by src/server/services/calendarService.ts) opens the
                 app directly at that route instead of the browser. android:host is
                 @string/app_domain — set the real domain there before building
                 (deploy/ANDROID.md "Deep links"). autoVerify requires
                 https://<domain>/.well-known/assetlinks.json to list this app's signing
                 certificate fingerprint, otherwise Android silently falls back to
                 showing the browser/app disambiguation sheet instead of opening
                 Hello Picnic directly. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="@string/app_domain" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Scan flow (src/app/(shell)/meer/scannen) uses a plain HTML
         <input type="file" capture="environment"> — no @capacitor/camera plugin. Inside
         Capacitor's WebView that still routes through Android's native file-chooser /
         camera intent, which needs the app to hold CAMERA at runtime on API 23+
         (deploy/ANDROID.md "Camera permission"); without it the WebView silently drops
         the "take photo" option and only offers the file browser. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>
